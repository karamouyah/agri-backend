# Backend environment variables — set all of these in Railway's backend service Variables tab.
# Do NOT commit real values to git.

# Django core
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-minimum-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=agri-app-production-4d98.up.railway.app

# CORS — set to your Railway frontend URL once it is assigned
CORS_ALLOWED_ORIGINS=https://your-frontend-service.up.railway.app

# CSRF — include both the backend and frontend Railway URLs
CSRF_TRUSTED_ORIGINS=https://agri-app-production-4d98.up.railway.app,https://your-frontend-service.up.railway.app

# Neon PostgreSQL
DATABASE_URL=postgresql://neondb_owner:npg_kD1nXIdYStm4@ep-sweet-mud-alkmo08b-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT token lifetimes (optional — these are the defaults)
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Railway terminates SSL at its proxy — Django must NOT redirect to HTTPS itself
SECURE_SSL_REDIRECT=False
